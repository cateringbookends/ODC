# Runtime SQLite database (regenerated from schema.sql on first run)
odc.db
odc.db-journal
odc.db-wal
odc.db-shm

# Dependencies (none currently; zero-dep server)
node_modules/

# Playwright CLI session logs / artifacts
.playwright-cli/

# PII / HR data files — never commit
*.xlsx
*.xls
*.csv

# Python cache
__pycache__/
*.pyc
*.pyo

# Output artifacts
output/

# Cloudflare tunnel binary (52MB, not needed in repo)
cloudflared.exe

# Google Sheets sync credentials (contains secret API key)
google-sync-config.json

# OS / editor cruft
Thumbs.db
.DS_Store
*.log
verify-ui.js
verify-screenshots/
